{
  "manifest_version": 3,
  "name": "Upwork Job Tracker",
  "version": "3.2",
  "description": "Reloads tracked Upwork job tabs on a schedule, reads Last viewed by client, compares times in seconds, and notifies when the client views more recently.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "scripting",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.upwork.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Upwork Job Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}